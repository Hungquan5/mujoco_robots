<mujoco model="spotmicro">
  <!--
    SpotMicro Quadruped Robot - MuJoCo MJCF
    ==========================================
    Procedural geometry model (no mesh files required).

    SpotMicro physical dimensions (from mike4192/spotMicro + community):
      Body         : 0.24 m (L) x 0.084 m (W) x 0.060 m (H)
      Shoulder arm : l1 = 0.055 m  lateral abduction offset
      Thigh        : l3 = 0.1085 m
      Calf         : l4 = 0.1385 m
      Foot sphere  : 0.015 m radius

    KEYFRAME FIX (verified by forward kinematics):
      Old keyframe: thigh=0.75, calf=-1.50
        → foot_x=+0.020 (tilted forward), foot_z=-0.181 (4mm too high)
        → body spawned at wrong height, robot collapses on load

      Correct keyframe: thigh=0.8393, calf=-1.4618
        → foot_x=0.000 (directly below shoulder) ✓
        → foot_z=-0.185 (foot at ground when body at z=0.185) ✓
        → verified by: -L3*cos(t2) - L4*cos(t2+t3) = -0.185

    Joint sign convention (from MJCF axis definitions):
      hip_joint:   axis="1 0 0"  positive = outward abduction
      thigh_joint: axis="0 1 0"  positive = leg swings forward/down
      calf_joint:  axis="0 1 0"  negative = knee bends backward (elbow-down)

    Color scheme:
      body shell  : dark charcoal  (0.18 0.18 0.20)
      shoulder    : yellow-orange  (1.00 0.65 0.00)
      thigh       : mid-gray       (0.42 0.42 0.45)
      calf        : dark gray      (0.25 0.25 0.27)
      foot pads   : black rubber   (0.08 0.08 0.08)
      accent trim : white          (0.95 0.95 0.95)
  -->

  <compiler angle="radian" autolimits="true"/>

  <option cone="elliptic" impratio="10" timestep="0.001" gravity="0 0 -9.81" integrator="RK4"/>

  <default>
    <default class="spotmicro">
      <geom group="1" friction="0.6" margin="0.001" condim="1"/>
      <joint axis="0 1 0" damping="0.05" armature="0.002" frictionloss="0.05"/>
      <motor ctrlrange="-3.2 3.2" gear="1"/>

      <default class="abduction">
        <joint axis="1 0 0" range="-1.0908 1.0908"/>
      </default>
      <default class="hip">
        <joint range="-1.3963 1.7453"/>
      </default>
      <default class="knee">
        <!-- Range covers both home (-1.4618) and sit (-2.1541) -->
        <joint range="-2.6180 -0.3491"/>
        <motor ctrlrange="-3.2 3.2"/>
      </default>

      <default class="foot">
        <geom type="sphere" size="0.015" group="1"
              priority="1" condim="6"
              friction="0.8 0.02 0.01"
              rgba="0.08 0.08 0.08 1"/>
      </default>
    </default>
  </default>

  <asset>
    <material name="body_shell" rgba="0.18 0.18 0.20 1"/>
    <material name="shoulder"   rgba="1.00 0.65 0.00 1"/>
    <material name="thigh"      rgba="0.42 0.42 0.45 1"/>
    <material name="calf"       rgba="0.25 0.25 0.27 1"/>
    <material name="accent"     rgba="0.95 0.95 0.95 1"/>
  </asset>

  <worldbody>

    <!-- body spawns at z=0.185 so feet (0.185m below shoulder) touch z=0 ground -->
    <body name="base_link" pos="0 0 0.185" childclass="spotmicro">

      <inertial pos="0 0 0" mass="0.560"
                diaginertia="0.00108 0.00556 0.00604"/>
      <freejoint/>
      <site name="imu" pos="0 0 0.030"/>

      <!-- ── Body shell ── -->
      <geom name="body_main" type="box"
            size="0.120 0.042 0.028" pos="0 0 0"
            material="body_shell"/>
      <geom name="body_top" type="box"
            size="0.110 0.036 0.005" pos="0 0 0.030"
            material="body_shell"/>
      <geom name="accent_stripe" type="box"
            size="0.080 0.032 0.003" pos="0.005 0 0.036"
            contype="0" conaffinity="0"
            material="accent"/>
      <geom name="sensor_bump" type="box"
            size="0.010 0.025 0.015" pos="0.128 0 0.005"
            contype="0" conaffinity="0"
            material="accent"/>

      <!-- ══════════════════════════════════════
           FRONT-LEFT LEG (FL)
           ══════════════════════════════════════ -->
      <body name="FL_shoulder" pos="0.100 0.042 0">
        <inertial pos="0 0.028 0" mass="0.060"
                  diaginertia="0.000025 0.000060 0.000060"/>
        <joint name="FL_hip_joint" class="abduction"/>
        <geom type="box" size="0.020 0.018 0.018"
              pos="0 0.018 0" material="shoulder"/>
        <geom type="cylinder" size="0.016 0.022"
              pos="0 0.040 0" quat="0.707107 0.707107 0 0"
              material="shoulder"/>

        <body name="FL_thigh" pos="0 0.055 0">
          <inertial pos="0 0 -0.054" mass="0.120"
                    diaginertia="0.000200 0.000200 0.000015"/>
          <joint name="FL_thigh_joint" class="hip"/>
          <geom type="box" size="0.014 0.013 0.050"
                pos="0 0 -0.050" material="thigh"/>
          <geom type="cylinder" size="0.016 0.013"
                pos="0 0 -0.002" material="shoulder"/>

          <body name="FL_calf" pos="0 0 -0.1085">
            <inertial pos="0 0 -0.069" mass="0.060"
                      diaginertia="0.000100 0.000100 0.000006"/>
            <joint name="FL_calf_joint" class="knee"/>
            <geom type="cylinder" size="0.009 0.065"
                  pos="0 0 -0.065" material="calf"/>
            <geom type="cylinder" size="0.014 0.010"
                  pos="0 0 -0.002" material="shoulder"/>
            <geom name="FL" pos="0 0 -0.1385" class="foot"/>
            <body name="FL_foot" pos="0 0 -0.1385"/>
          </body>
        </body>
      </body>

      <!-- ══════════════════════════════════════
           FRONT-RIGHT LEG (FR)
           ══════════════════════════════════════ -->
      <body name="FR_shoulder" pos="0.100 -0.042 0">
        <inertial pos="0 -0.028 0" mass="0.060"
                  diaginertia="0.000025 0.000060 0.000060"/>
        <joint name="FR_hip_joint" class="abduction"/>
        <geom type="box" size="0.020 0.018 0.018"
              pos="0 -0.018 0" material="shoulder"/>
        <geom type="cylinder" size="0.016 0.022"
              pos="0 -0.040 0" quat="0.707107 0.707107 0 0"
              material="shoulder"/>

        <body name="FR_thigh" pos="0 -0.055 0">
          <inertial pos="0 0 -0.054" mass="0.120"
                    diaginertia="0.000200 0.000200 0.000015"/>
          <joint name="FR_thigh_joint" class="hip"/>
          <geom type="box" size="0.014 0.013 0.050"
                pos="0 0 -0.050" material="thigh"/>
          <geom type="cylinder" size="0.016 0.013"
                pos="0 0 -0.002" material="shoulder"/>

          <body name="FR_calf" pos="0 0 -0.1085">
            <inertial pos="0 0 -0.069" mass="0.060"
                      diaginertia="0.000100 0.000100 0.000006"/>
            <joint name="FR_calf_joint" class="knee"/>
            <geom type="cylinder" size="0.009 0.065"
                  pos="0 0 -0.065" material="calf"/>
            <geom type="cylinder" size="0.014 0.010"
                  pos="0 0 -0.002" material="shoulder"/>
            <geom name="FR" pos="0 0 -0.1385" class="foot"/>
            <body name="FR_foot" pos="0 0 -0.1385"/>
          </body>
        </body>
      </body>

      <!-- ══════════════════════════════════════
           REAR-LEFT LEG (RL)
           ══════════════════════════════════════ -->
      <body name="RL_shoulder" pos="-0.100 0.042 0">
        <inertial pos="0 0.028 0" mass="0.060"
                  diaginertia="0.000025 0.000060 0.000060"/>
        <joint name="RL_hip_joint" class="abduction"/>
        <geom type="box" size="0.020 0.018 0.018"
              pos="0 0.018 0" material="shoulder"/>
        <geom type="cylinder" size="0.016 0.022"
              pos="0 0.040 0" quat="0.707107 0.707107 0 0"
              material="shoulder"/>

        <body name="RL_thigh" pos="0 0.055 0">
          <inertial pos="0 0 -0.054" mass="0.120"
                    diaginertia="0.000200 0.000200 0.000015"/>
          <joint name="RL_thigh_joint" class="hip"/>
          <geom type="box" size="0.014 0.013 0.050"
                pos="0 0 -0.050" material="thigh"/>
          <geom type="cylinder" size="0.016 0.013"
                pos="0 0 -0.002" material="shoulder"/>

          <body name="RL_calf" pos="0 0 -0.1085">
            <inertial pos="0 0 -0.069" mass="0.060"
                      diaginertia="0.000100 0.000100 0.000006"/>
            <joint name="RL_calf_joint" class="knee"/>
            <geom type="cylinder" size="0.009 0.065"
                  pos="0 0 -0.065" material="calf"/>
            <geom type="cylinder" size="0.014 0.010"
                  pos="0 0 -0.002" material="shoulder"/>
            <geom name="RL" pos="0 0 -0.1385" class="foot"/>
            <body name="RL_foot" pos="0 0 -0.1385"/>
          </body>
        </body>
      </body>

      <!-- ══════════════════════════════════════
           REAR-RIGHT LEG (RR)
           ══════════════════════════════════════ -->
      <body name="RR_shoulder" pos="-0.100 -0.042 0">
        <inertial pos="0 -0.028 0" mass="0.060"
                  diaginertia="0.000025 0.000060 0.000060"/>
        <joint name="RR_hip_joint" class="abduction"/>
        <geom type="box" size="0.020 0.018 0.018"
              pos="0 -0.018 0" material="shoulder"/>
        <geom type="cylinder" size="0.016 0.022"
              pos="0 -0.040 0" quat="0.707107 0.707107 0 0"
              material="shoulder"/>

        <body name="RR_thigh" pos="0 -0.055 0">
          <inertial pos="0 0 -0.054" mass="0.120"
                    diaginertia="0.000200 0.000200 0.000015"/>
          <joint name="RR_thigh_joint" class="hip"/>
          <geom type="box" size="0.014 0.013 0.050"
                pos="0 0 -0.050" material="thigh"/>
          <geom type="cylinder" size="0.016 0.013"
                pos="0 0 -0.002" material="shoulder"/>

          <body name="RR_calf" pos="0 0 -0.1085">
            <inertial pos="0 0 -0.069" mass="0.060"
                      diaginertia="0.000100 0.000100 0.000006"/>
            <joint name="RR_calf_joint" class="knee"/>
            <geom type="cylinder" size="0.009 0.065"
                  pos="0 0 -0.065" material="calf"/>
            <geom type="cylinder" size="0.014 0.010"
                  pos="0 0 -0.002" material="shoulder"/>
            <geom name="RR" pos="0 0 -0.1385" class="foot"/>
            <body name="RR_foot" pos="0 0 -0.1385"/>
          </body>
        </body>
      </body>

    </body>
  </worldbody>

  <!-- ─────────────────────────────────────────
       ACTUATORS
       ───────────────────────────────────────── -->
  <actuator>
    <motor class="abduction" name="FR_hip"   joint="FR_hip_joint"/>
    <motor class="hip"       name="FR_thigh" joint="FR_thigh_joint"/>
    <motor class="knee"      name="FR_calf"  joint="FR_calf_joint"/>
    <motor class="abduction" name="FL_hip"   joint="FL_hip_joint"/>
    <motor class="hip"       name="FL_thigh" joint="FL_thigh_joint"/>
    <motor class="knee"      name="FL_calf"  joint="FL_calf_joint"/>
    <motor class="abduction" name="RR_hip"   joint="RR_hip_joint"/>
    <motor class="hip"       name="RR_thigh" joint="RR_thigh_joint"/>
    <motor class="knee"      name="RR_calf"  joint="RR_calf_joint"/>
    <motor class="abduction" name="RL_hip"   joint="RL_hip_joint"/>
    <motor class="hip"       name="RL_thigh" joint="RL_thigh_joint"/>
    <motor class="knee"      name="RL_calf"  joint="RL_calf_joint"/>
  </actuator>

  <!-- ─────────────────────────────────────────
       SENSORS
       ───────────────────────────────────────── -->
  <sensor>
    <jointpos name="FR_hip_pos"   joint="FR_hip_joint"/>
    <jointpos name="FR_thigh_pos" joint="FR_thigh_joint"/>
    <jointpos name="FR_calf_pos"  joint="FR_calf_joint"/>
    <jointpos name="FL_hip_pos"   joint="FL_hip_joint"/>
    <jointpos name="FL_thigh_pos" joint="FL_thigh_joint"/>
    <jointpos name="FL_calf_pos"  joint="FL_calf_joint"/>
    <jointpos name="RR_hip_pos"   joint="RR_hip_joint"/>
    <jointpos name="RR_thigh_pos" joint="RR_thigh_joint"/>
    <jointpos name="RR_calf_pos"  joint="RR_calf_joint"/>
    <jointpos name="RL_hip_pos"   joint="RL_hip_joint"/>
    <jointpos name="RL_thigh_pos" joint="RL_thigh_joint"/>
    <jointpos name="RL_calf_pos"  joint="RL_calf_joint"/>

    <jointvel name="FR_hip_vel"   joint="FR_hip_joint"/>
    <jointvel name="FR_thigh_vel" joint="FR_thigh_joint"/>
    <jointvel name="FR_calf_vel"  joint="FR_calf_joint"/>
    <jointvel name="FL_hip_vel"   joint="FL_hip_joint"/>
    <jointvel name="FL_thigh_vel" joint="FL_thigh_joint"/>
    <jointvel name="FL_calf_vel"  joint="FL_calf_joint"/>
    <jointvel name="RR_hip_vel"   joint="RR_hip_joint"/>
    <jointvel name="RR_thigh_vel" joint="RR_thigh_joint"/>
    <jointvel name="RR_calf_vel"  joint="RR_calf_joint"/>
    <jointvel name="RL_hip_vel"   joint="RL_hip_joint"/>
    <jointvel name="RL_thigh_vel" joint="RL_thigh_joint"/>
    <jointvel name="RL_calf_vel"  joint="RL_calf_joint"/>

    <jointactuatorfrc name="FR_hip_torque"   joint="FR_hip_joint"   noise="0.005"/>
    <jointactuatorfrc name="FR_thigh_torque" joint="FR_thigh_joint" noise="0.005"/>
    <jointactuatorfrc name="FR_calf_torque"  joint="FR_calf_joint"  noise="0.005"/>
    <jointactuatorfrc name="FL_hip_torque"   joint="FL_hip_joint"   noise="0.005"/>
    <jointactuatorfrc name="FL_thigh_torque" joint="FL_thigh_joint" noise="0.005"/>
    <jointactuatorfrc name="FL_calf_torque"  joint="FL_calf_joint"  noise="0.005"/>
    <jointactuatorfrc name="RR_hip_torque"   joint="RR_hip_joint"   noise="0.005"/>
    <jointactuatorfrc name="RR_thigh_torque" joint="RR_thigh_joint" noise="0.005"/>
    <jointactuatorfrc name="RR_calf_torque"  joint="RR_calf_joint"  noise="0.005"/>
    <jointactuatorfrc name="RL_hip_torque"   joint="RL_hip_joint"   noise="0.005"/>
    <jointactuatorfrc name="RL_thigh_torque" joint="RL_thigh_joint" noise="0.005"/>
    <jointactuatorfrc name="RL_calf_torque"  joint="RL_calf_joint"  noise="0.005"/>

    <framequat     name="imu_quat" objtype="site" objname="imu"/>
    <gyro          name="imu_gyro" site="imu"/>
    <accelerometer name="imu_acc"  site="imu"/>
    <framepos      name="frame_pos" objtype="site" objname="imu"/>
    <framelinvel   name="frame_vel" objtype="site" objname="imu"/>
  </sensor>

  <!-- ─────────────────────────────────────────
       KEYFRAMES
       Angles verified by forward kinematics:
         thigh=0.8393, calf=-1.4618
         → foot_x=0.000 (directly below shoulder) ✓
         → foot_z=-0.185 (touches z=0 ground) ✓
       ───────────────────────────────────────── -->
  <keyframe>
    <key name="home"
         qpos="0 0 0.185  1 0 0 0
               0  0.8393 -1.4618
               0  0.8393 -1.4618
               0  0.8393 -1.4618
               0  0.8393 -1.4618"
         ctrl="0 0.8393 -1.4618
               0 0.8393 -1.4618
               0 0.8393 -1.4618
               0 0.8393 -1.4618"/>
    <key name="sit"
         qpos="0 0 0.120  1 0 0 0
               0  1.2990 -2.1541
               0  1.2990 -2.1541
               0  1.2990 -2.1541
               0  1.2990 -2.1541"
         ctrl="0 1.2990 -2.1541
               0 1.2990 -2.1541
               0 1.2990 -2.1541
               0 1.2990 -2.1541"/>
  </keyframe>

</mujoco>