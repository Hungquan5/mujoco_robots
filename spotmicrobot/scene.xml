<mujoco model="spotmicro scene">
  <!--
    SpotMicro Scene
    ===============
    Includes the SpotMicro robot (spotmicro.xml) and a full obstacle course
    adapted from the Go2 scene. Obstacles are scaled down to suit SpotMicro's
    smaller body (~0.185 m standing height vs Go2's ~0.445 m).

    Scale factor applied: ~0.4× on heights/sizes so steps/ramps are
    challenging but not impossible for SpotMicro.

    Layout (along +X axis from robot spawn at origin):
      0.0  m : SpotMicro spawn
      0.6  m : Low hurdle rails  (2× thin boxes)
      1.2  m : Tilted ramp slab
      1.8  m : Staircase ascending (10 steps, 0.02 m rise each)
      3.5  m : Staircase descending thin-step variant
      5.0  m : Rocky rubble field (random-rotated boxes, from Go2 scene)
      7.0  m : Perlin height field terrain
      9.0  m : Image-based height field terrain
  -->

  <!-- Include the robot model -->
  <include file="spotmicro.xml"/>

  <!-- Camera framing: tighter extent for small robot -->
  <statistic center="0 0 0.05" extent="0.5"/>

  <!-- ─────────────────────────────────────────
       VISUAL SETTINGS
       Same mood as Go2 scene (blue-grey sky, soft haze)
       ───────────────────────────────────────── -->
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <!-- ─────────────────────────────────────────
       ASSETS
       ───────────────────────────────────────── -->
  <asset>
    <!-- Sky gradient: deep blue-black -->
    <texture type="skybox" builtin="gradient"
             rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>

    <!-- Checker ground plane -->
    <texture type="2d" name="groundplane" builtin="checker"
             mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane"
              texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <!-- Obstacle concrete material -->
    <material name="concrete" rgba="0.55 0.55 0.52 1"/>

  </asset>

  <!-- ─────────────────────────────────────────
       WORLD BODY
       ───────────────────────────────────────── -->
  <worldbody>

    <!-- Sun light -->
    <light pos="0 0 2" dir="0 0 -1" directional="true"
           diffuse="0.8 0.8 0.8" specular="0.1 0.1 0.1"/>
    <!-- Fill light from front -->
    <light pos="2 -1 1.5" dir="-1 0.5 -1" directional="true"
           diffuse="0.25 0.28 0.35" specular="0 0 0"/>

    <!-- ── Ground plane ── -->
    <geom name="floor" size="0 0 0.05" type="plane"
          material="groundplane"/>

    <!-- ════════════════════════════════════════
         ZONE 1 — Low hurdle rails  (x ≈ 0.6 m)
         Two thin flat rails the robot must step over.
         height 0.016 m, width 0.005 m, span 1 m in Y
         ════════════════════════════════════════ -->
    <geom name="hurdle_1" pos="0.60 0 0.016" type="box"
          size="0.005 0.5 0.016" quat="1 0 0 0"
          material="concrete"/>
    <geom name="hurdle_2" pos="0.80 0 0.016" type="box"
          size="0.005 0.5 0.016" quat="1 0 0 0"
          material="concrete"/>

    <!-- ════════════════════════════════════════
         ZONE 2 — Tilted ramp slab  (x ≈ 1.2 m)
         ~14° incline, similar to Go2 scene ramp
         (Go2 used quat 0.969 0 -0.247 0 → ~28°; halved for SpotMicro)
         ════════════════════════════════════════ -->
    <geom name="ramp" pos="1.20 0 0.06" type="box"
          size="0.30 0.50 0.025"
          quat="0.992 0 -0.124 0"
          material="concrete"/>

    <!-- ════════════════════════════════════════
         ZONE 3 — Ascending staircase  (x ≈ 1.8 – 3.0 m)
         10 steps, each 0.10 m deep × 0.02 m rise
         Full-width Y = 0.40 m (SpotMicro body is 0.084 m wide)
         Derived from Go2 staircase block pattern, scaled ×0.27 height
         ════════════════════════════════════════ -->
    <geom name="step_a01" pos="1.80 0 0.010" type="box" size="0.05 0.40 0.010" material="concrete"/>
    <geom name="step_a02" pos="1.90 0 0.030" type="box" size="0.05 0.40 0.030" material="concrete"/>
    <geom name="step_a03" pos="2.00 0 0.050" type="box" size="0.05 0.40 0.050" material="concrete"/>
    <geom name="step_a04" pos="2.10 0 0.070" type="box" size="0.05 0.40 0.070" material="concrete"/>
    <geom name="step_a05" pos="2.20 0 0.090" type="box" size="0.05 0.40 0.090" material="concrete"/>
    <geom name="step_a06" pos="2.30 0 0.110" type="box" size="0.05 0.40 0.110" material="concrete"/>
    <geom name="step_a07" pos="2.40 0 0.130" type="box" size="0.05 0.40 0.130" material="concrete"/>
    <geom name="step_a08" pos="2.50 0 0.150" type="box" size="0.05 0.40 0.150" material="concrete"/>
    <geom name="step_a09" pos="2.60 0 0.170" type="box" size="0.05 0.40 0.170" material="concrete"/>
    <geom name="step_a10" pos="2.70 0 0.190" type="box" size="0.05 0.40 0.190" material="concrete"/>

    <!-- ════════════════════════════════════════
         ZONE 4 — Descending thin-step staircase  (x ≈ 3.0 – 4.0 m)
         Thinner slabs (Go2 scene "thin" variant), descending
         ════════════════════════════════════════ -->
    <geom name="step_d01" pos="3.00 0 0.190" type="box" size="0.05 0.40 0.008" material="concrete"/>
    <geom name="step_d02" pos="3.12 0 0.165" type="box" size="0.05 0.40 0.008" material="concrete"/>
    <geom name="step_d03" pos="3.24 0 0.140" type="box" size="0.05 0.40 0.008" material="concrete"/>
