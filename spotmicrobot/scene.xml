    <geom name="step_d05" pos="3.48 0 0.090" type="box" size="0.05 0.40 0.008" material="concrete"/>
    <geom name="step_d06" pos="3.60 0 0.065" type="box" size="0.05 0.40 0.008" material="concrete"/>
    <geom name="step_d07" pos="3.72 0 0.040" type="box" size="0.05 0.40 0.008" material="concrete"/>
    <geom name="step_d08" pos="3.84 0 0.015" type="box" size="0.05 0.40 0.008" material="concrete"/>

