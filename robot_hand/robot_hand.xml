<mujoco>
<option>
    <flag contact="enable"/>
</option>
<asset>
<texture name="grid" type="2d" builtin="checker"
         width="1024" height="1024"
         rgb1="0.9 0.9 0.9"
         rgb2="0.1 0.1 0.1"/>

<material name="grid_mat"
          texture="grid"
          texrepeat="8 8"
          texuniform="true"/>
</asset>
    <worldbody>
    <geom name="floor" type="plane" pos="0 0 0" size= "50 50 0.1" material="grid_mat"/>
<!-- Forearm -->
        <body name="forearm" pos="0 0 0.1" >
            <inertial mass="0.05" pos="0 0 0" diaginertia="0.0001 0.0001 0.0001"/>
            <geom type="capsule" size="0.03 0.15" rgba="0.6 0.6 0.6 1" density="1000"/>

            <!-- Wrist joint -->
            <joint name="wrist_joint" type="hinge" axis="0 1 0" pos="0 0 0.15"/>

            <!-- Palm -->
            <body name="palm" pos="0 0 0.15" euler="0 0 0">
                <geom type="box" size="0.05 0.04 0.015" rgba="0.8 0.7 0.6 1" density="800"/>
                <!-- Finger base -->
                <body name="finger_base" pos="0.03 0 0">
                   
                    <geom type="capsule" size="0.01 0.04" rgba="0.9 0.8 0.7 1"/>
 <joint name="finger_base_joint" 
       type="hinge"
       axis="0 1 0"
       range="0 90"
       damping="1"/>
                    <!-- Middle phalanx -->
                    <body name="finger_mid" pos="0 0 0.08">
                        <joint name="finger_mid_joint" type="hinge" axis="0 1 0" range="0 90"/>

                        <geom type="capsule" size="0.009 0.03" density="800"/>

                        <!-- Finger tip -->
                        <body name="finger_tip" pos="0 0 0.06">
                            <joint name="finger_tip_joint" type="hinge" axis="0 1 0" range="0 90"/>

                            <geom type="capsule" size="0.008 0.02"/>

                        </body>

                    </body>

                </body>

            </body>

        </body>

    </worldbody>

    <actuator>

        <motor joint="wrist_joint" name="wrist_motor" ctrlrange="-1 1"/>

        <motor joint="finger_base_joint" name="finger_base_motor" ctrlrange="-1 1"/>
        <motor joint="finger_mid_joint" name="finger_mid_motor" ctrlrange="-1 1"/>
        <motor joint="finger_tip_joint" name="finger_tip_motor" ctrlrange="-1 1"/>
    </actuator>

</mujoco>