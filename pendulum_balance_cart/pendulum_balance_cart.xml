<mujoco>
  <option timestep="0.0001" gravity="0 0 -9.81" integrator="RK4">
    <flag warmstart="enable"/>
  </option>
<asset>
    <texture name="grid" type="2d" builtin="checker" width="1024" height="1024" rgb1="0.9 0.9 0.9" rgb2="0.1 0.1 0.1"/>
    <material name="grid_mat" texture="grid" texrepeat="8 8" texuniform="true"/>
</asset>
<worldbody>
    <light diffuse="0.8 0.8 0.8" pos="0 0 3" dir="0 0 -1"/>
    <geom name="floor" type="plane" pos="0 0 0" size="5 5 0.1" material="grid_mat"/>
    <body name="table" pos="0 0 1">
        <geom type="box" size="1 0.1 0.1" rgba="0.8 0.6 0.4 1"/>
        <body name="table_foot_right" pos="1 0 -0.5">
            <geom type="box" size="0.05 0.05 0.5" rgba="0.8 0.6 0.4 1"/>
        </body>
        <body name="table_foot_left" pos="-1 0 -0.5">
            <geom type="box" size="0.05 0.05 0.5" rgba="0.8 0.6 0.4 1"/>
        </body>
    </body>
<body name="cart" pos="0 0 1.3">
  <geom type="box" size="0.2 0.1 0.1" rgba="0.2 0.2 0.8 1"/>
  <joint name="cart_slide" type="slide" axis="1 0 0" limited="true" range="-100 100"/>
  <!-- pole is child of cart => connected -->
  <body name="pole" pos="0 0.17 0.1">
    <joint name="pole_hinge" type="hinge" axis="0 1 0"   pos="0 0 0" damping="0.1"/>
    <geom type="cylinder" size="0.02 0.2" pos="0 0 0.2" rgba="0.8 0.2 0.2 1"/>
      <body name="pole_pole" pos="0 0 0.4" euler="0 0 0">
    <joint name="pole_pole_hinge" type="hinge" axis="0 1 0"   pos="0 0 0" damping="0.1"/>
    <geom type="cylinder" size="0.02 0.2" pos="0 0 0.2" rgba="0.8 0.2 0.2 1"/>
          <body name="pole_pole_pole" pos="0 0 0.4" euler="0 0 0">
            <joint name="pole_pole_pole_hinge" type="hinge" axis="0 1 0"   pos="0 0 0" damping="0.1"/>
            <geom type="cylinder" size="0.02 0.2" pos="0 0 0.2" rgba="0.8 0.2 0.2 1"/>
    </body>
    </body>
  </body>
</body>
</worldbody>
<contact>
    <exclude body1="pole" body2="pole_pole"/>
    <exclude body1="pole" body2="pole_pole_pole"/>
    <exclude body1="pole_pole" body2="pole_pole_pole"/>
    <exclude body1="cart" body2="pole_pole"/>
    <exclude body1="cart" body2="pole_pole_pole"/>
</contact>
<actuator>
    <motor name="cart_motor" joint="cart_slide" />
</actuator>
<sensor>
    <jointpos name="jointpos" joint="cart_slide"/>
    <jointvel name="jointvel" joint="cart_slide"/>
    <jointpos name="pole_hinge_pos" joint="pole_hinge"/>
    <jointvel name="pole_hinge_vel" joint="pole_hinge"/>
    <jointpos name="pole_pole_hinge_pos" joint="pole_pole_hinge"/>
    <jointvel name="pole_pole_hinge_vel" joint="pole_pole_hinge"/>
    <jointpos name="pole_pole_pole_hinge_pos" joint="pole_pole_pole_hinge"/>
    <jointvel name="pole_pole_pole_hinge_vel" joint="pole_pole_pole_hinge"/>
</sensor>
</mujoco>